terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
    dispatcher = {
      source  = "terraform.local/stowzilla/dispatcher"
      version = "99.0.0"
    }
  }
}

provider "aws" {
  region = var.aws_region

  default_tags {
    tags = {
      Project     = "<%= @app_name.capitalize %>"
      Environment = var.environment
      ManagedBy   = "Terraform"
    }
  }
}

provider "dispatcher" {
  environment = var.environment
  aws_region  = var.aws_region
}
